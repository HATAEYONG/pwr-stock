# PowerStock 환경변수 설정
# .env 파일을 생성하고 아래 값들을 설정하세요

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (기본: SQLite)
# PostgreSQL을 사용하려면 주석 해제하고 설정
# DATABASE_URL=postgresql://user:password@localhost:5432/powerstock

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Email (선택사항)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Celery (선택사항 - Redis 필요)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 키움증권 API
KIWOOM_API_ENABLED=False  # True로 설정 시 실제 API 사용 (Windows 전용)
